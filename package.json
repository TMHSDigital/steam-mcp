{
  "name": "@tmhs/steam-mcp",
  "version": "0.5.1",
  "description": "MCP server for Steam and Steamworks APIs - 20 tools for querying and writing Steam store data, player statistics, achievements, reviews, pricing, workshop items, leaderboards, inventory, lobbies, and player profiles from AI-powered IDEs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "steam-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "author": "TMHSDigital",
  "license": "CC-BY-NC-ND-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/TMHSDigital/Steam-MCP"
  },
  "homepage": "https://github.com/TMHSDigital/Steam-MCP#readme",
  "bugs": {
    "url": "https://github.com/TMHSDigital/Steam-MCP/issues"
  },
  "keywords": [
    "steam",
    "mcp",
    "model-context-protocol",
    "steamworks",
    "cursor",
    "ai-tools"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
